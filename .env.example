# SPAS / Investment Academy 环境变量配置
# 复制本文件为 .env 并填入真实值

# Tushare Pro API Token（用于 fetch_real_data.py 和数据源回退）
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_API_URL=https://ts.gyzcloud.top/api

# SPAS Core API 地址（投资学院后端代理用）
SPAS_API_URL=http://127.0.0.1:8000/api/spas

# 投资学院后端数据更新接口的本地访问密钥（用于 /api/manual-analysis/update-data）
# 留空则关闭该端点
IA_UPDATE_SECRET=change_me_to_a_random_secret

# 可选：运行环境
# ENV=development
